---
import Base from '../../layouts/Base.astro';
import PostArticle from '../../components/PostArticle.astro';
import { getPosts, getPost, hasVersion, readingMinutes } from '../../lib/posts';
import { localizedPath } from '../../i18n/ui';
import { render } from 'astro:content';

// Gera uma pagina por post PT (rota dinamica via getCollection -> getStaticPaths)
export async function getStaticPaths() {
  const posts = await getPosts('pt');
  return posts.map((p) => ({ params: { slug: p.data.slug } }));
}

const lang = 'pt' as const;
const slug = Astro.params.slug!;
const post = await getPost(lang, slug);
if (!post) throw new Error(`Post PT não encontrado: ${slug}`);

const { Content } = await render(post);
const minutes = readingMinutes(post.body);

// Slug compartilhado: o toggle leva ao mesmo write-up em EN se existir.
const enExists = await hasVersion(post.data.slug, 'en');
const ptHref = localizedPath('pt', `blog/${post.data.slug}`);
const enHref = enExists ? localizedPath('en', `blog/${post.data.slug}`) : null;
---

<Base
  lang={lang}
  active="blog"
  title={`${post.data.title} — CTIWitch`}
  description={post.data.summary}
  ptHref={ptHref}
  enHref={enHref}
>
  <PostArticle lang={lang} post={post} minutes={minutes} Content={Content} />
</Base>
