---
import Base from '../layouts/Base.astro';
import Resume from '../components/Resume.astro';
import cv from '../data/cv.pt.json';
import { localizedPath } from '../i18n/ui';
---

<Base
  lang="pt"
  active="home"
  title="The OSINT W1tch · CTI Analyst"
  description={cv.heroBlurb}
  ptHref={localizedPath('pt', '')}
  enHref={localizedPath('en', '')}
>
  <Resume lang="pt" cv={cv} blogHref={localizedPath('pt', 'blog')} />
</Base>
