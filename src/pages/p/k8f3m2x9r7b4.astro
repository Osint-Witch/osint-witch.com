---
import '../../styles/global.css';
import CloudCompanion from '../../components/CloudCompanion.astro';
import cvPt from '../../data/cv-real.pt.json';
import cvEn from '../../data/cv-real.en.json';

const pt = cvPt;
const en = cvEn;
---

<!doctype html>
<html lang="pt">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Currículo</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body>

    <!-- NAV -->
    <header class="nav">
      <div class="nav-inner">
        <span class="brand">
          <span class="brand-badge">⬡</span>
          <span class="brand-text">osint-witch<span>.com</span></span>
        </span>
        <div class="nav-right">
          <div class="lang-toggle" role="group">
            <button id="btn-pt" class="lang-btn is-active" onclick="setLang('pt')">PT</button>
            <button id="btn-en" class="lang-btn" onclick="setLang('en')">EN</button>
          </div>
        </div>
      </div>
    </header>

    <!-- CONTEÚDO PT -->
    <div id="cv-pt">
      <main class="wrap">
        <section class="hero">
          <div>
            <div class="badge"><span class="badge-dot"></span>{pt.available}</div>
            <h1 class="hero-name">{pt.name}</h1>
            <p class="hero-role">{pt.role}</p>
            <p class="hero-tag">{pt.tagline}</p>
            <p class="hero-blurb">{pt.heroBlurb}</p>
            <div class="hero-actions">
              <a class="btn btn-ghost lift" href={pt.cvFile} download>↓ {pt.downloadLabel}</a>
            </div>
          </div>
          <div>
            <div class="terminal">
              <div class="term-bar">
                <span class="term-dot" style="background:#ff6ec7"></span>
                <span class="term-dot" style="background:#ffd86e"></span>
                <span class="term-dot" style="background:#5ef2a0"></span>
                <span class="term-path">~/whoami</span>
              </div>
              <div class="term-body">
                <div><span class="c-prompt">$</span> whoami</div>
                <div><span class="c-cyan">{pt.name}</span></div>
                <div><span class="c-prompt">$</span> cat role.txt</div>
                <div><span class="c-lilac">{pt.role}</span></div>
                <div><span class="c-prompt">$</span> location --now</div>
                <div><span class="c-pink">{pt.location}</span></div>
                <div><span class="c-prompt">$</span> uptime --years</div>
                <div><span class="c-yellow">{pt.years}</span><span class="term-cursor">&nbsp;</span></div>
              </div>
            </div>
          </div>
        </section>
        <section class="section">
          <div class="kicker tight">// SOBRE</div>
          {pt.about.map((p) => <p class="lead">{p}</p>)}
        </section>
        <section class="section">
          <div class="kicker">// EXPERIÊNCIA</div>
          {pt.experience.map((job) => (
            <div class="xp-item">
              <div class="xp-period">{job.period}</div>
              <div>
                <h3 class="xp-role">{job.role}</h3>
                <div class="xp-org">{job.org}</div>
                {job.bullets.map((b) => (
                  <div class="xp-bullet"><span class="mk">▸</span><span>{b}</span></div>
                ))}
              </div>
            </div>
          ))}
        </section>
        <section class="section">
          <div class="kicker">// SKILLS & FERRAMENTAS</div>
          <div class="skills-grid">
            {pt.skills.map((grp) => (
              <div class="skill-card lift">
                <div class="skill-head"><span class="ic">{grp.icon}</span>{grp.group}</div>
                <div class="chips">{grp.items.map((it) => <span class="chip">{it}</span>)}</div>
              </div>
            ))}
          </div>
        </section>
        <section class="section">
          <div class="kicker">// CERTIFICAÇÕES</div>
          <div class="certs-grid">
            {pt.certs.map((c) => (
              <div class="cert-card lift">
                <div class="cert-kind">{c.kind}</div>
                <div class="cert-name">{c.name}</div>
                <div class="cert-issuer">{c.issuer}</div>
              </div>
            ))}
          </div>
        </section>
        <section class="contact">
          <div class="contact-card">
            <div class="kicker tight" style="color:var(--cyan)">// CONTATO</div>
            <h2 class="contact-title">{pt.contactTitle}</h2>
            <p class="contact-blurb">{pt.contactBlurb}</p>
            <div class="contact-links">
              {pt.contacts.map((c) => (
                <a class="contact-link" href={c.href} target={c.href.startsWith('http') ? '_blank' : undefined} rel={c.href.startsWith('http') ? 'noopener' : undefined}>{c.icon} {c.label}</a>
              ))}
            </div>
          </div>
        </section>
      </main>
    </div>

    <!-- CONTEÚDO EN -->
    <div id="cv-en" style="display:none">
      <main class="wrap">
        <section class="hero">
          <div>
            <div class="badge"><span class="badge-dot"></span>{en.available}</div>
            <h1 class="hero-name">{en.name}</h1>
            <p class="hero-role">{en.role}</p>
            <p class="hero-tag">{en.tagline}</p>
            <p class="hero-blurb">{en.heroBlurb}</p>
            <div class="hero-actions">
              <a class="btn btn-ghost lift" href={en.cvFile} download>↓ {en.downloadLabel}</a>
            </div>
          </div>
          <div>
            <div class="terminal">
              <div class="term-bar">
                <span class="term-dot" style="background:#ff6ec7"></span>
                <span class="term-dot" style="background:#ffd86e"></span>
                <span class="term-dot" style="background:#5ef2a0"></span>
                <span class="term-path">~/whoami</span>
              </div>
              <div class="term-body">
                <div><span class="c-prompt">$</span> whoami</div>
                <div><span class="c-cyan">{en.name}</span></div>
                <div><span class="c-prompt">$</span> cat role.txt</div>
                <div><span class="c-lilac">{en.role}</span></div>
                <div><span class="c-prompt">$</span> location --now</div>
                <div><span class="c-pink">{en.location}</span></div>
                <div><span class="c-prompt">$</span> uptime --years</div>
                <div><span class="c-yellow">{en.years}</span><span class="term-cursor">&nbsp;</span></div>
              </div>
            </div>
          </div>
        </section>
        <section class="section">
          <div class="kicker tight">// ABOUT</div>
          {en.about.map((p) => <p class="lead">{p}</p>)}
        </section>
        <section class="section">
          <div class="kicker">// EXPERIENCE</div>
          {en.experience.map((job) => (
            <div class="xp-item">
              <div class="xp-period">{job.period}</div>
              <div>
                <h3 class="xp-role">{job.role}</h3>
                <div class="xp-org">{job.org}</div>
                {job.bullets.map((b) => (
                  <div class="xp-bullet"><span class="mk">▸</span><span>{b}</span></div>
                ))}
              </div>
            </div>
          ))}
        </section>
        <section class="section">
          <div class="kicker">// SKILLS & TOOLSET</div>
          <div class="skills-grid">
            {en.skills.map((grp) => (
              <div class="skill-card lift">
                <div class="skill-head"><span class="ic">{grp.icon}</span>{grp.group}</div>
                <div class="chips">{grp.items.map((it) => <span class="chip">{it}</span>)}</div>
              </div>
            ))}
          </div>
        </section>
        <section class="section">
          <div class="kicker">// CERTIFICATIONS</div>
          <div class="certs-grid">
            {en.certs.map((c) => (
              <div class="cert-card lift">
                <div class="cert-kind">{c.kind}</div>
                <div class="cert-name">{c.name}</div>
                <div class="cert-issuer">{c.issuer}</div>
              </div>
            ))}
          </div>
        </section>
        <section class="contact">
          <div class="contact-card">
            <div class="kicker tight" style="color:var(--cyan)">// CONTACT</div>
            <h2 class="contact-title">{en.contactTitle}</h2>
            <p class="contact-blurb">{en.contactBlurb}</p>
            <div class="contact-links">
              {en.contacts.map((c) => (
                <a class="contact-link" href={c.href} target={c.href.startsWith('http') ? '_blank' : undefined} rel={c.href.startsWith('http') ? 'noopener' : undefined}>{c.icon} {c.label}</a>
              ))}
            </div>
          </div>
        </section>
      </main>
    </div>

    <footer class="footer">
      <span id="footer-text">feito com ☁️ por CTI Witch · osint-witch.com · estático no GitHub Pages</span>
    </footer>

    <CloudCompanion lang="pt" />

    <script>
      function setLang(lang: string) {
        const ptDiv = document.getElementById('cv-pt')!;
        const enDiv = document.getElementById('cv-en')!;
        const btnPt = document.getElementById('btn-pt')!;
        const btnEn = document.getElementById('btn-en')!;
        const footer = document.getElementById('footer-text')!;
        const html = document.documentElement;

        if (lang === 'en') {
          ptDiv.style.display = 'none';
          enDiv.style.display = '';
          btnPt.classList.remove('is-active');
          btnEn.classList.add('is-active');
          html.lang = 'en';
          footer.textContent = 'made with ☁️ by CTI Witch · osint-witch.com · static on GitHub Pages';
        } else {
          enDiv.style.display = 'none';
          ptDiv.style.display = '';
          btnEn.classList.remove('is-active');
          btnPt.classList.add('is-active');
          html.lang = 'pt';
          footer.textContent = 'feito com ☁️ por CTI Witch · osint-witch.com · estático no GitHub Pages';
        }
      }
    </script>

  </body>
</html>
