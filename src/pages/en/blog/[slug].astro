---
import Base from '../../../layouts/Base.astro';
import PostArticle from '../../../components/PostArticle.astro';
import { getPosts, getPost, hasVersion, readingMinutes } from '../../../lib/posts';
import { localizedPath } from '../../../i18n/ui';
import { render } from 'astro:content';

// Gera uma pagina por post EN
export async function getStaticPaths() {
  const posts = await getPosts('en');
  return posts.map((p) => ({ params: { slug: p.data.slug } }));
}

const lang = 'en' as const;
const slug = Astro.params.slug!;
const post = await getPost(lang, slug);
if (!post) throw new Error(`EN post not found: ${slug}`);

const { Content } = await render(post);
const minutes = readingMinutes(post.body);

const ptExists = await hasVersion(post.data.slug, 'pt');
const ptHref = ptExists ? localizedPath('pt', `blog/${post.data.slug}`) : null;
const enHref = localizedPath('en', `blog/${post.data.slug}`);
---

<Base
  lang={lang}
  active="blog"
  title={`${post.data.title} — OSINT W1tch`}
  description={post.data.summary}
  ptHref={ptHref}
  enHref={enHref}
>
  <PostArticle lang={lang} post={post} minutes={minutes} Content={Content} />
</Base>
