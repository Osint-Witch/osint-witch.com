---
import Base from '../../../layouts/Base.astro';
import BlogList from '../../../components/BlogList.astro';
import { getPosts, getTags } from '../../../lib/posts';
import { localizedPath } from '../../../i18n/ui';

const posts = await getPosts('en');
const tags = await getTags('en');
---

<Base
  lang="en"
  active="blog"
  title="Blog — CTI Witch"
  description="Cyber Threat Intelligence write-ups: threat hunting, OSINT and threat analysis."
  ptHref={localizedPath('pt', 'blog')}
  enHref={localizedPath('en', 'blog')}
>
  <BlogList lang="en" posts={posts} tags={tags} />
</Base>
