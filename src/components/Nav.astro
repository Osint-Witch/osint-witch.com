---
import { useTranslations, localizedPath, type Lang } from '../i18n/ui';
import LangToggle from './LangToggle.astro';

interface Props {
  lang: Lang;
  active?: 'home' | 'blog';
  ptHref: string | null;
  enHref: string | null;
}
const { lang, active = 'home', ptHref, enHref } = Astro.props;
const t = useTranslations(lang);

const homeHref = localizedPath(lang, '');
const blogHref = localizedPath(lang, 'blog');
---

<header class="nav">
  <div class="nav-inner">
    <a class="brand" href={homeHref} aria-label="CTIWitch">
      <span class="brand-badge">⬡</span>
      <span class="brand-text">ctiwitch<span>.com</span></span>
    </a>

    <nav class="nav-links">
      <a class={`nav-link ${active === 'home' ? 'is-active' : ''}`} href={homeHref}>{t('nav.home')}</a>
      <a class={`nav-link ${active === 'blog' ? 'is-active' : ''}`} href={blogHref}>{t('nav.blog')}</a>
    </nav>

    <div class="nav-right">
      <!-- O som da nuvenzinha (padrao desligado). O script da nuvem cuida do toggle. -->
      <button id="cti-sound" class="icon-btn" type="button" title={t('sound.tip')} aria-pressed="false" aria-label={t('sound.tip')}>🔇</button>
      <LangToggle lang={lang} ptHref={ptHref} enHref={enHref} />
    </div>
  </div>
</header>
