---
import { useTranslations, type Lang } from '../i18n/ui';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div id="cti-coinlayer" aria-hidden="true"></div>

<button id="cti-cloud" type="button" title={t('cloud.tip')} aria-label={t('cloud.tip')}>
<svg id="eye-svg" width="128" height="128" viewBox="0 0 64 64" style="overflow:visible;">
  <defs>
    <radialGradient id="ec-iris" cx="42%" cy="32%" r="58%">
      <stop offset="0%"   stop-color="#e8fff8"/>
      <stop offset="8%"   stop-color="#5cffd8"/>
      <stop offset="28%"  stop-color="#a78bff"/>
      <stop offset="52%"  stop-color="#6b22d4"/>
      <stop offset="72%"  stop-color="#2d0a80"/>
      <stop offset="88%"  stop-color="#110535"/>
      <stop offset="100%" stop-color="#060018"/>
    </radialGradient>
    <radialGradient id="ec-sclera" cx="46%" cy="36%" r="62%">
      <stop offset="0%"   stop-color="#f5f0ff"/>
      <stop offset="55%"  stop-color="#e4deff"/>
      <stop offset="88%"  stop-color="#c8beed"/>
      <stop offset="100%" stop-color="#a898d0"/>
    </radialGradient>
    <radialGradient id="ec-gloss" cx="40%" cy="18%" r="72%">
      <stop offset="0%"   stop-color="#ffffff" stop-opacity="0.42"/>
      <stop offset="45%"  stop-color="#ffffff" stop-opacity="0.12"/>
      <stop offset="100%" stop-color="#ffffff" stop-opacity="0"/>
    </radialGradient>
    <radialGradient id="ec-shadow" cx="50%" cy="0%" r="80%">
      <stop offset="0%"   stop-color="#05000f" stop-opacity="0.55"/>
      <stop offset="100%" stop-color="#05000f" stop-opacity="0"/>
    </radialGradient>
    <radialGradient id="ec-aura" cx="50%" cy="50%" r="50%">
      <stop offset="0%"   stop-color="#a78bff" stop-opacity="0.22"/>
      <stop offset="100%" stop-color="#a78bff" stop-opacity="0"/>
    </radialGradient>
    <linearGradient id="ec-lid-top" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%"   stop-color="#a78bff"/>
      <stop offset="50%"  stop-color="#e0d8ff"/>
      <stop offset="100%" stop-color="#2ee6d6"/>
    </linearGradient>
    <linearGradient id="ec-lid-bot" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%"   stop-color="#7b55cc"/>
      <stop offset="50%"  stop-color="#b0a0e8"/>
      <stop offset="100%" stop-color="#22b0a8"/>
    </linearGradient>
    <filter id="ec-glow" x="-40%" y="-40%" width="180%" height="180%">
      <feGaussianBlur stdDeviation="2" result="b"/>
      <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
    <filter id="ec-drop" x="-40%" y="-40%" width="180%" height="180%">
      <feDropShadow dx="0" dy="3" stdDeviation="5" flood-color="#5500cc" flood-opacity="0.6"/>
    </filter>
    <filter id="ec-aura-blur" x="-80%" y="-80%" width="260%" height="260%">
      <feGaussianBlur stdDeviation="8"/>
    </filter>
    <filter id="ec-gr" x="-12%" y="-12%" width="124%" height="124%">
      <feOffset dx="4" dy="-1" result="o"/>
      <feFlood flood-color="#ff6ec7" flood-opacity="0.65" result="c"/>
      <feComposite in="c" in2="o" operator="in" result="g"/>
      <feMerge><feMergeNode in="g"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
    <filter id="ec-gc" x="-12%" y="-12%" width="124%" height="124%">
      <feOffset dx="-4" dy="1" result="o"/>
      <feFlood flood-color="#2ee6d6" flood-opacity="0.65" result="c"/>
      <feComposite in="c" in2="o" operator="in" result="g"/>
      <feMerge><feMergeNode in="g"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
    <clipPath id="ec-eye-clip">
      <path d="M6,32 C22,10 42,10 58,32 C42,54 22,54 6,32 Z"/>
    </clipPath>
  </defs>

  <!-- aura -->
  <ellipse cx="32" cy="32" rx="30" ry="24" fill="url(#ec-aura)" filter="url(#ec-aura-blur)"/>

  <!-- sombra projetada -->
  <ellipse cx="32" cy="40" rx="22" ry="6" fill="#3a00aa" opacity="0.28" filter="url(#ec-drop)"/>

  <!-- esclera -->
  <path d="M6,32 C22,10 42,10 58,32 C42,54 22,54 6,32 Z"
        fill="url(#ec-sclera)" filter="url(#ec-drop)"/>

  <g clip-path="url(#ec-eye-clip)">
    <!-- íris + pupila (grupo que se move com cursor) -->
    <g id="ec-iris-group">
      <circle cx="32" cy="32" r="14" fill="url(#ec-iris)"/>

      <!-- fibras radiais (coordenadas dentro do raio da íris) -->
      <g opacity="0.22">
        <line x1="32" y1="22" x2="32" y2="19.5" stroke="#2ee6d6" stroke-width="0.8"/>
        <line x1="36" y1="23" x2="38.5" y2="20.5" stroke="#a78bff" stroke-width="0.7"/>
        <line x1="39.5" y1="27" x2="42.5" y2="24.5" stroke="#2ee6d6" stroke-width="0.7"/>
        <line x1="41" y1="32" x2="44.5" y2="32" stroke="#a78bff" stroke-width="0.7"/>
        <line x1="39.5" y1="37" x2="42.5" y2="39.5" stroke="#2ee6d6" stroke-width="0.7"/>
        <line x1="36" y1="41" x2="38.5" y2="43.5" stroke="#a78bff" stroke-width="0.7"/>
        <line x1="32" y1="42" x2="32" y2="44.5" stroke="#2ee6d6" stroke-width="0.8"/>
        <line x1="28" y1="41" x2="25.5" y2="43.5" stroke="#a78bff" stroke-width="0.7"/>
        <line x1="24.5" y1="37" x2="21.5" y2="39.5" stroke="#2ee6d6" stroke-width="0.7"/>
        <line x1="23" y1="32" x2="19.5" y2="32" stroke="#a78bff" stroke-width="0.7"/>
        <line x1="24.5" y1="27" x2="21.5" y2="24.5" stroke="#2ee6d6" stroke-width="0.7"/>
        <line x1="28" y1="23" x2="25.5" y2="20.5" stroke="#a78bff" stroke-width="0.7"/>
        <line x1="37.5" y1="25" x2="40" y2="22.5" stroke="#2ee6d6" stroke-width="0.5"/>
        <line x1="26.5" y1="25" x2="24" y2="22.5" stroke="#a78bff" stroke-width="0.5"/>
        <line x1="37.5" y1="39" x2="40" y2="41.5" stroke="#a78bff" stroke-width="0.5"/>
        <line x1="26.5" y1="39" x2="24" y2="41.5" stroke="#2ee6d6" stroke-width="0.5"/>
      </g>

      <!-- anel limbal -->
      <circle cx="32" cy="32" r="14" fill="none" stroke="#040010" stroke-width="3.5"/>

      <!-- pupila fenda vertical -->
      <ellipse id="ec-pupil"       cx="32" cy="32" rx="3.2" ry="9.5" fill="#010008"/>
      <ellipse id="ec-pupil-inner" cx="32" cy="32" rx="2"   ry="8"   fill="#000005"/>
      <ellipse id="ec-pupil-shine" cx="33.2" cy="29" rx="1.1" ry="0.7"
               fill="white" opacity="0.65" transform="rotate(-15 33.2 29)"/>
    </g>

    <!-- sombra da pálpebra superior (fixa) -->
    <ellipse cx="32" cy="14" rx="22" ry="14" fill="url(#ec-shadow)"/>

    <!-- cornea gloss (fixa — reflexo do ambiente) -->
    <ellipse cx="30" cy="26" rx="16" ry="10"
             fill="url(#ec-gloss)" transform="rotate(-8 30 26)"/>

    <!-- catchlights (fixas) -->
    <ellipse cx="37" cy="24" rx="4.5" ry="2.6" fill="white" opacity="0.96"
             transform="rotate(-22 37 24)" filter="url(#ec-glow)"/>
    <circle cx="25" cy="40" r="1.8" fill="white" opacity="0.36"/>
  </g>

  <!-- bordas robustas -->
  <path d="M6,32 C22,10 42,10 58,32"
        fill="none" stroke="url(#ec-lid-top)" stroke-width="3.2" stroke-linecap="round"/>
  <path d="M6,32 C22,10 42,10 58,32"
        fill="none" stroke="white" stroke-width="0.7" stroke-linecap="round" opacity="0.2"/>
  <path d="M6,32 C22,54 42,54 58,32"
        fill="none" stroke="url(#ec-lid-bot)" stroke-width="2" stroke-linecap="round"/>

  <!-- cantos 3D -->
  <circle cx="6"  cy="32" r="3.5" fill="#8855ee" opacity="0.95"/>
  <circle cx="6"  cy="31" r="1.2" fill="white"   opacity="0.6"/>
  <circle cx="58" cy="32" r="3.5" fill="#22ccbe" opacity="0.95"/>
  <circle cx="58" cy="31" r="1.2" fill="white"   opacity="0.6"/>

  <!-- pálpebras blink -->
  <path id="ec-lid-top-blink" d="M6,32 C22,10 42,10 58,32 Z" fill="#07060f" opacity="0"/>
  <path id="ec-lid-bot-blink" d="M6,32 C22,54 42,54 58,32 Z" fill="#07060f" opacity="0"/>
</svg>
</button>

<style>
  #cti-coinlayer {
    position: fixed; inset: 0; pointer-events: none; z-index: 60; overflow: hidden;
  }
  #cti-cloud {
    position: fixed; left: 0; top: 0; width: 128px; height: 128px; z-index: 55;
    padding: 0; border: none; background: none; cursor: pointer; pointer-events: auto;
    will-change: transform;
  }
  @keyframes eyefloat {
    0%   { opacity: 1; transform: translateY(0); }
    100% { opacity: 0; transform: translateY(-52px); }
  }
  @keyframes eyepoof {
    0%   { transform: scale(0.2); opacity: 0.85; }
    100% { transform: scale(2.8); opacity: 0; }
  }
</style>

<script>
  const btn      = document.getElementById('cti-cloud');
  const eyeSvg   = document.getElementById('eye-svg');
  const irisGrp  = document.getElementById('ec-iris-group');
  const pupil    = document.getElementById('ec-pupil');
  const pupilIn  = document.getElementById('ec-pupil-inner');
  const shine    = document.getElementById('ec-pupil-shine');
  const lidTop   = document.getElementById('ec-lid-top-blink');
  const lidBot   = document.getElementById('ec-lid-bot-blink');
  const layer    = document.getElementById('cti-coinlayer');

  if (btn && eyeSvg && irisGrp && pupil && pupilIn && shine && lidTop && lidBot && layer) {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let cx = window.innerWidth - 260, cy = 80;
    let mx = cx + 64, my = cy + 64;
    let ex = 0, ey = 0, squish = 0;
    let nextBlink  = performance.now() + 1600 + Math.random() * 2000;
    let blinkUntil = 0;
    let nextGlitch = performance.now() + 4000 + Math.random() * 5000;
    let glitching  = false, glitchUntil = 0;
    let mode: 'float' | 'curious' | 'hesitate' = 'float';
    let modeUntil  = performance.now() + 3000;
    let lastEmote  = 0, lastScan = performance.now();

    window.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; });
    btn.addEventListener('click', react);

    const chars = ['0x', '//', '>>', '##', '??', '01', 'FF', '&&'];

    function react() {
      squish = 1;
      const px = cx + 64, py = cy + 64;
      for (let k = 0; k < 7; k++) {
        const el  = document.createElement('div');
        const ang = Math.random() * Math.PI * 2;
        const d   = 36 + Math.random() * 44;
        el.textContent = chars[Math.floor(Math.random() * chars.length)];
        el.style.cssText = `position:absolute;left:${px+Math.cos(ang)*d-10}px;top:${py+Math.sin(ang)*d-10}px;font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:700;color:${Math.random()>.5?'#2ee6d6':'#a78bff'};pointer-events:none;animation:eyefloat 1s ease-out forwards;`;
        layer!.appendChild(el);
        setTimeout(() => el.remove(), 1050);
      }
      const ring = document.createElement('div');
      ring.style.cssText = `position:absolute;left:${px-38}px;top:${py-38}px;width:76px;height:76px;border-radius:50%;border:2px solid #a78bff;pointer-events:none;animation:eyepoof .55s ease-out forwards;`;
      layer!.appendChild(ring);
      setTimeout(() => ring.remove(), 600);
    }

    function emote(txt: string) {
      if (performance.now() - lastEmote < 1400) return;
      lastEmote = lastScan = performance.now();
      const el = document.createElement('div');
      el.textContent = txt;
      el.style.cssText = `position:absolute;left:${cx+100}px;top:${cy+20}px;font-family:'JetBrains Mono',monospace;font-size:13px;color:#2ee6d6;font-weight:700;letter-spacing:.04em;pointer-events:none;animation:eyefloat 1.4s ease-out forwards;`;
      layer!.appendChild(el);
      setTimeout(() => el.remove(), 1450);
    }

    if (reduced) {
      btn.style.transform = `translate(${cx}px,${cy}px)`;
    } else {
      const t0 = performance.now();
      const loop = (now: number) => {
        const t = (now - t0) / 1000;
        const anchorX = window.innerWidth - 260 + Math.sin(t * .42) * 22;
        const anchorY = 80 + Math.sin(t * .65) * 14;

        if (now > modeUntil) {
          if (mode === 'float') {
            mode = Math.random() < .28 ? 'curious' : 'float';
            modeUntil = now + 2200 + Math.random() * 3200;
          } else if (mode === 'curious') {
            mode = 'hesitate'; modeUntil = now + 400 + Math.random() * 700;
          } else {
            mode = 'float'; modeUntil = now + 2600 + Math.random() * 3600;
          }
        }

        let tx: number, ty: number, ease: number;
        if      (mode === 'curious')  { tx = cx+(mx-64-cx)*.5; ty = cy+(my-64-cy)*.5; ease = .022; }
        else if (mode === 'hesitate') { tx = cx; ty = cy; ease = .013; }
        else                          { tx = anchorX; ty = anchorY; ease = .014; }

        cx += (tx-cx)*ease; cy += (ty-cy)*ease;
        squish *= 0.82;
        btn.style.transform = `translate(${cx.toFixed(1)}px,${cy.toFixed(1)}px) scale(${(1+squish*.18).toFixed(3)},${(1-squish*.14).toFixed(3)})`;

        const dx = mx-(cx+64), dy = my-(cy+64);
        const dist = Math.hypot(dx, dy);
        const tpx = dist > 1 ? (dx/dist)*Math.min(dist*.08, 4.5) : 0;
        const tpy = dist > 1 ? (dy/dist)*Math.min(dist*.08, 4.5) : 0;
        ex += (tpx-ex)*.1; ey += (tpy-ey)*.1;

        const prox = Math.max(0, 1-dist/380);
        const pCx = (32+ex).toFixed(2);
        const pCy = (32+ey).toFixed(2);
        pupil!.setAttribute('cx', pCx);
        pupil!.setAttribute('cy', pCy);
        pupilIn!.setAttribute('cx', pCx);
        pupilIn!.setAttribute('cy', pCy);
        shine!.setAttribute('cx', (33.2+ex*.7).toFixed(2));
        shine!.setAttribute('cy', (29+ey*.7).toFixed(2));
        irisGrp!.setAttribute('transform', `translate(${(ex*.35).toFixed(2)},${(ey*.35).toFixed(2)})`);

        pupil!.setAttribute('rx', Math.max(2.2, 3.2-prox*1.2).toFixed(1));
        pupil!.setAttribute('ry', Math.min(12.5, 9.5+prox*4).toFixed(1));
        pupilIn!.setAttribute('rx', Math.max(1.4, 2-prox*.8).toFixed(1));
        pupilIn!.setAttribute('ry', Math.min(11, 8+prox*3.5).toFixed(1));

        if (now > nextBlink) { blinkUntil = now+100; nextBlink = now+1800+Math.random()*3200; }
        const bl = now < blinkUntil ? '1' : '0';
        lidTop!.setAttribute('opacity', bl);
        lidBot!.setAttribute('opacity', bl);

        if (now > nextGlitch && !glitching) {
          glitching = true; glitchUntil = now+55+Math.random()*130;
          nextGlitch = now+5000+Math.random()*7000;
        }
        if (glitching) {
          if (now < glitchUntil) {
            (eyeSvg as HTMLElement).style.filter = Math.random()>.5
              ? 'url(#ec-gr) drop-shadow(0 0 22px rgba(167,139,255,.9))'
              : 'url(#ec-gc) drop-shadow(0 0 22px rgba(46,230,214,.9))';
          } else {
            glitching = false;
            (eyeSvg as HTMLElement).style.filter = 'drop-shadow(0 0 24px rgba(167,139,255,.6))';
            emote(Math.random()>.5 ? 'scan...' : '0x??');
          }
        } else {
          (eyeSvg as HTMLElement).style.filter = 'drop-shadow(0 0 24px rgba(167,139,255,.5))';
        }

        if (mode==='float' && dist>300 && now-lastScan>6000) emote('scanning...');
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    }
  }
</script>
