---
import { useTranslations, type Lang } from '../i18n/ui';

interface CVContact { icon: string; label: string; href: string; }
interface CVJob { period: string; role: string; org: string; bullets: string[]; }
interface CVSkill { group: string; icon: string; items: string[]; }
interface CVCert { kind: string; name: string; issuer: string; }
interface CV {
  available: string; name: string; role: string; tagline: string;
  location: string; years: string; downloadLabel: string; cvFile: string;
  heroBlurb: string; about: string[]; experience: CVJob[]; skills: CVSkill[];
  certs: CVCert[]; contactTitle: string; contactBlurb: string; contacts: CVContact[];
}

interface Props { lang: Lang; cv: CV; blogHref: string; }
const { lang, cv, blogHref } = Astro.props;
const t = useTranslations(lang);
---

<main class="wrap">
  <!-- HERO -->
  <section class="hero">
    <div>
      <h1 class="hero-name">{cv.name}</h1>
      <p class="hero-tag">{cv.tagline}</p>
      <p class="hero-blurb">{cv.heroBlurb}</p>
      <div class="hero-actions">
        <a class="btn btn-primary lift" href={blogHref}>{t('hero.readBlog')}</a>
      </div>
    </div>

    <!-- terminal whoami -->
    <div>
      <div class="terminal">
        <div class="term-bar">
          <span class="term-dot" style="background:#ff6ec7"></span>
          <span class="term-dot" style="background:#ffd86e"></span>
          <span class="term-dot" style="background:#5ef2a0"></span>
          <span class="term-path">~/whoami</span>
        </div>
        <div class="term-body">
          <div><span class="c-prompt">$</span> whoami</div>
          <div><span class="c-cyan">{cv.name}</span></div>
          <div><span class="c-prompt">$</span> cat role.txt</div>
          <div><span class="c-lilac">{cv.role}</span></div>
          <div><span class="c-prompt">$</span> uptime --years</div>
          <div><span class="c-yellow">{cv.years}</span><span class="term-cursor">&nbsp;</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- SKILLS -->
  <section class="section">
    <div class="kicker">// {t('section.skills')}</div>
    <div class="skills-grid">
      {cv.skills.map((grp) => (
        <div class="skill-card lift">
          <div class="skill-head"><span class="ic">{grp.icon}</span>{grp.group}</div>
          <div class="chips">
            {grp.items.map((it) => <span class="chip">{it}</span>)}
          </div>
        </div>
      ))}
    </div>
  </section>

</main>
